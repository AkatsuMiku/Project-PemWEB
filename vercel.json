{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    {
      "source": "/tiket",
      "destination": "/tiket/tiket.html"
    },
    {
      "source": "/tiket/",
      "destination": "/tiket/tiket.html"
    },
    {
      "source": "/index",
      "destination": "/"
    },
    {
      "source": "/index/index.php",
      "destination": "/"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}